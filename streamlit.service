[Unit]
Description=AI Songwriting System Streamlit App
After=network.target

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/AI-Songwriting-System
Environment="PATH=/home/ubuntu/AI-Songwriting-System/venv/bin"
ExecStart=/home/ubuntu/AI-Songwriting-System/venv/bin/streamlit run frontend/app.py --server.port 8501 --server.address 0.0.0.0
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
